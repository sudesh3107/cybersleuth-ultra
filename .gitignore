# CyberSleuth Ultra — .gitignore

# ── Scan Output Files ────────────────────────────────
*.json
*.html
*.txt
!requirements.txt
*.log

# ── API Keys / Secrets (NEVER commit these) ──────────
.env
.env.*
secrets.py
config_local.py

# ── Python ───────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
.installed.cfg

# ── Virtual Environments ──────────────────────────────
venv/
env/
.venv/
.env/
ENV/

# ── IDEs ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Testing ───────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
